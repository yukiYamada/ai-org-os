# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Env
.env
.env.*
!.env.example

# Node
node_modules/
.npm/
.pnpm-store/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Build / Dist
dist/
build/
out/
coverage/

# Temp
*.tmp
*.temp
.tmp/

# Runtime artifacts
*.pid

# ai-org-os: generated Mind instances (Mindspaces). Not committed; lifecycle is managed by runtime.
runtime/minds/*
!runtime/minds/.gitkeep

# ai-org-os: Nexus storage (Dispatch messages). Not committed; managed at runtime.
runtime/nexus/storage/inbox/*
!runtime/nexus/storage/inbox/.gitkeep
runtime/nexus/storage/archive/*
!runtime/nexus/storage/archive/.gitkeep

# Python
*.pyc
__pycache__/
*.egg-info/
