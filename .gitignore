# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Env
.env
.env.*
!.env.example

# Node
node_modules/
.npm/
.pnpm-store/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Build / Dist
dist/
build/
out/
coverage/

# Temp
*.tmp
*.temp
.tmp/

# Runtime artifacts
*.pid

# ai-org-os: generated Mind instances (Mindspaces). Not committed; lifecycle is managed by runtime.
runtime/minds/*
!runtime/minds/.gitkeep

# ai-org-os: Nexus storage (Dispatch messages). Not committed; managed at runtime.
runtime/pillars/conduit/storage/inbox/*
!runtime/pillars/conduit/storage/inbox/.gitkeep
runtime/pillars/conduit/storage/archive/*
!runtime/pillars/conduit/storage/archive/.gitkeep

# ai-org-os: Observation Pillar snapshots (v0.1, ROADMAP). Host-local, not committed.
runtime/pillars/observation/snapshots/*
!runtime/pillars/observation/snapshots/.gitkeep

# Python
*.pyc
__pycache__/
*.egg-info/
runtime/pillars/conduit/.venv/
