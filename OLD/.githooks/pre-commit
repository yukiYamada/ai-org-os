#!/usr/bin/env bash
set -euo pipefail

# Guardrails最小チェック（ドキュメント運用向け）
# - 機密情報の平文コミット防止
# - 1PR=1目的を意識した変更量上限の警告

echo "[guardrails] pre-commit: チェック開始"

# 1) 機密情報パターン（簡易）
if git diff --cached --name-only | grep -Eq '.'; then
  if git diff --cached | grep -E 'AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9]{20,}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----' >/dev/null; then
    echo "[guardrails][NG] 機密情報らしき文字列を検出。コミットを中断します。"
    echo "[guardrails][HINT] G-05 機密情報の平文保存禁止（org/global_rules.md）"
    exit 1
  fi
fi

# 2) 変更ファイル数（強制ではなく警告）
changed_count=$(git diff --cached --name-only | wc -l | tr -d ' ')
if [ "${changed_count}" -gt 3 ]; then
  echo "[guardrails][WARN] 変更ファイル数=${changed_count}（推奨: 3以下）"
  echo "[guardrails][HINT] G-08 大粒変更の一括投入禁止。必要ならPR分割を検討してください。"
fi

# 3) 新規 Markdown ドキュメントに「想定読者」が含まれるかを警告
# - 運営原則 7. Reader-Aware Documentation に対応
# - 対象: 新規追加された .md ファイル（テンプレ・MEMORY・CHANGELOG・LICENSE 等は除外）
new_md_files=$(git diff --cached --name-only --diff-filter=A | grep -E '\.md$' || true)
for f in ${new_md_files}; do
  case "${f}" in
    templates/*|*/CHANGELOG.md|*/MEMORY.md|LICENSE*) continue ;;
  esac
  if [ -f "${f}" ]; then
    head -n 10 "${f}" | grep -qE '想定読者|Audience|Target reader' || {
      echo "[guardrails][WARN] 新規ドキュメント '${f}' の冒頭10行に「想定読者」が見つかりません。"
      echo "[guardrails][HINT] 運営原則 7. Reader-Aware Documentation（org/operating_principles.md）"
    }
  fi
done

# 4) docs/product_vision.md を変更する場合は decisions.md 記録の有無を警告
if git diff --cached --name-only | grep -q '^docs/product_vision.md$'; then
  if ! git diff --cached --name-only | grep -q 'memory/decisions.md$'; then
    echo "[guardrails][WARN] product_vision.md を変更していますが、decisions.md の更新が含まれていません。"
    echo "[guardrails][HINT] Vision 更新は意思決定の記録（背景/選択肢/決定/影響）が必要です。"
  fi
fi

echo "[guardrails] pre-commit: チェック完了"
